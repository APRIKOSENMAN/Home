# Lokale Entwicklung - kopiere diese Datei zu ".env" und trage deine Werte ein.
# Die .env-Datei wird NIEMALS zu GitHub gepusht (steht in .gitignore).

# PostgreSQL-Verbindung (aus Railway kopieren - steht unter Variables)
DATABASE_URL=postgresql://benutzername:passwort@host:port/datenbankname

# Port auf dem der Server lokal laeuft (3000 ist Standard, kannst du so lassen)
PORT=3000
